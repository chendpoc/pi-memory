{
  "name": "@chendpoc/pi-memory",
  "version": "0.3.2",
  "description": "Cross-session episodic memory for Pi agent — MEMORY.md ground truth, JSONL sidecar retrieval, and Preflight injection",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extension": {
      "types": "./dist/pi-extension.d.ts",
      "import": "./dist/pi-extension.js"
    }
  },
  "bin": {
    "pi-memory": "./dist/cli.js",
    "pi-memory-sidecar": "./dist/sidecar/server/process.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc -p tsconfig.dist.json",
    "prepare": "node ./scripts/prepare.mjs",
    "postinstall": "node ./scripts/postinstall.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "rebuild:native": "pnpm rebuild better-sqlite3",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "doc/README-zh.md",
    "doc/ROADMAP.md",
    "doc/ROADMAP-zh.md",
    "doc/LAUNCH-KIT.md",
    "templates/MEMORY.md.example",
    "templates/com.pi.memory.consolidate.plist.example",
    "templates/consolidate.cmd.example",
    "templates/crontab.example",
    "templates/schtasks.example.txt",
    "scripts/path-utils.mjs",
    "scripts/init-memory-workspace.mjs",
    "scripts/platform-fs.mjs",
    "scripts/postinstall.mjs",
    "scripts/prepare.mjs",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "pnpm@10.12.1",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-agent",
    "episodic-memory",
    "agent-memory",
    "local-memory",
    "markdown-memory",
    "coding-agent",
    "ai-memory",
    "recent-memory",
    "memory-recall"
  ],
  "license": "MIT",
  "author": "chendpoc",
  "repository": {
    "type": "git",
    "url": "https://github.com/chendpoc/pi-memory.git"
  },
  "homepage": "https://github.com/chendpoc/pi-memory#readme",
  "pi": {
    "extensions": [
      "./dist/pi-extension.js"
    ],
    "image": "https://raw.githubusercontent.com/chendpoc/pi-memory/v0.3.1/assets/gallery/pi-memory-gallery.png"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "^1.1.38"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.5",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^24.0.0",
    "typebox": "^1.3.3",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "es-toolkit": "^1.49.0",
    "execa": "^9.6.1",
    "lru-cache": "^11.5.1",
    "proper-lockfile": "^4.1.2"
  }
}
