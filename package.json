{
  "name": "@chendpoc/pi-memory",
  "version": "0.1.13",
  "description": "Session-first local memory for Pi coding agent - recent sessions + MEMORY.md + memory_recall",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extension": {
      "types": "./dist/pi-extension.d.ts",
      "import": "./dist/pi-extension.js"
    }
  },
  "bin": {
    "pi-memory": "./dist/cli.js",
    "pi-memory-sidecar": "./dist/sidecar/server/process.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "rebuild:native": "pnpm rebuild better-sqlite3",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "pnpm@10.12.1",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-agent",
    "episodic-memory",
    "recent-memory",
    "memory-recall"
  ],
  "license": "MIT",
  "author": "chendpoc",
  "repository": {
    "type": "git",
    "url": "https://github.com/chendpoc/pi-memory.git"
  },
  "homepage": "https://github.com/chendpoc/pi-memory#readme",
  "pi": {
    "extensions": [
      "./src/pi-extension.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.5",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.0.0",
    "typebox": "*",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "lodash": "^4.18.1",
    "lru-cache": "^11.5.1",
    "proper-lockfile": "^4.1.2",
    "zod": "^4.4.3"
  }
}
