# Copy to ~/.pi/agent/pi-memory.env (recommended; stays beside Pi agent config).

# hash (default, offline) | ollama | openai
PI_MEMORY_EMBEDDER=hash

# Ollama (local — uncomment to enable)
# PI_MEMORY_EMBEDDER=ollama
# PI_MEMORY_OLLAMA_BASE_URL=http://127.0.0.1:11434
# PI_MEMORY_OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (cloud)
# PI_MEMORY_EMBEDDER=openai
# PI_MEMORY_OPENAI_API_KEY=sk-...
# PI_MEMORY_OPENAI_EMBED_MODEL=text-embedding-3-small

# Override embedding dimension when using a custom model
# PI_MEMORY_EMBED_DIM=768

# HTTP timeout for embed / LLM APIs (ms)
# PI_MEMORY_HTTP_TIMEOUT_MS=30000

# Helper LLM for QueryIntent (provider/model)
# PI_MEMORY_HELPER_MODEL=deepseek/deepseek-v4-flash
# PI_MEMORY_HELPER_API_KEY=sk-...

# Ollama LLM (optional; defaults to PI_MEMORY_OLLAMA_BASE_URL)
# PI_MEMORY_OLLAMA_LLM_MODEL=qwen3.5:2b

# OpenAI-compatible LLM (vLLM, etc.)
# PI_MEMORY_OPENAI_COMPAT_BASE_URL=http://127.0.0.1:8000
# PI_MEMORY_OPENAI_COMPAT_MODEL=...
# PI_MEMORY_OPENAI_COMPAT_API_KEY=...

# Preflight shared budget (ms) for QueryIntent + sidecar query; 250–1500
# PI_MEMORY_PREFLIGHT_BUDGET_MS=800
# PI_MEMORY_INTENT_RETRIES=0
# PI_MEMORY_WARM_SIDECAR=1
# PI_MEMORY_INTENT_CACHE=1
# PI_MEMORY_REINDEX_DEBOUNCE_MS=500

# Vector retrieval (sidecar query): top-K, MMR lambda (0–1), min cosine similarity (0–1)
# PI_MEMORY_TOP_K=3
# PI_MEMORY_MMR_LAMBDA=0.8
# PI_MEMORY_MIN_RELEVANCE=0.4

# Index chunking: split long Memory Entry bodies beyond this char limit (128–4000; 0 = off)
# PI_MEMORY_CHUNK_MAX_CHARS=512

# Debug stderr logs (preflight timings, CLI diagnostics)
# PI_MEMORY_DEBUG=1

# Disable scheduler sync while set.
# This affects automatic sync and manual `pi-memory scheduler sync`; unset it before manual sync.
# PI_MEMORY_SKIP_SCHEDULER_SYNC=1

# Memory data root (MEMORY.md, memory.vec.sqlite, sidecar socket).
# Default: ~/.pi/pi-memory-data (no need to set unless you want a custom path).
# PI_MEMORY_AGENT_DIR=~/custom-memory-data

# Explicit env file path (optional; overrides default ~/.pi/agent/pi-memory.env)
# PI_MEMORY_ENV_FILE=~/.pi/agent/pi-memory.env
